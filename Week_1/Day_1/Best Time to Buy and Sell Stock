class Solution {
public:
    int maxProfit(vector<int>& arr) {
        int profit = 0;

        int prev = arr[0];
        for(int i=1;i<arr.size();i++){
            int ans = arr[i] - prev;
            profit = max(profit,ans);
            prev = min(prev,arr[i]);
        }
        return profit;
    }
};
